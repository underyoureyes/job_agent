# Copy this file to .env and fill in your values
# Never commit .env to version control

# --- AI ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514

# --- Job board APIs ---
REED_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# --- Candidate details (used in generated documents) ---
CANDIDATE_NAME=Your Name
CANDIDATE_EMAIL=you@example.com
CANDIDATE_PHONE=+44 7700 000000
CANDIDATE_LINKEDIN=https://www.linkedin.com/in/your-profile/
CANDIDATE_LOCATION=City, Country
CANDIDATE_ADDRESS=Your Street Address
CANDIDATE_ADDRESS2=City, Postcode

# --- Reed auto-apply (optional) ---
# If set, the app will log in to Reed before submitting applications.
# Leave blank to skip login (some jobs may still be applyable as a guest).
REED_LOGIN_EMAIL=
REED_LOGIN_PASSWORD=

# --- LinkedIn Easy Apply (required for LinkedIn auto-apply) ---
# Must be a valid LinkedIn account. 2FA must be disabled or use an app password.
LINKEDIN_APPLY_EMAIL=
LINKEDIN_APPLY_PASSWORD=

# --- Session summary email ---
# Sends a summary email on app close if any activity occurred.
# Use a Gmail App Password (not your main password): myaccount.google.com/apppasswords
NOTIFY_EMAIL=you@email.com
SMTP_FROM=you@email.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your_app_password

# --- Output ---
# Where generated CVs and cover letters are saved (defaults to ./output if unset)
OUTPUT_DIR=/path/to/your/output/folder
